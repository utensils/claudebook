---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';

/* ── SESSION ─────────────────────────────── */
const session = [
  { cmd: '/clear', aliases: '/reset, /new', desc: 'Clear conversation history and free context' },
  { cmd: '/compact [instructions]', aliases: '', desc: 'Compact conversation with optional focus' },
  { cmd: '/resume [session]', aliases: '/continue', desc: 'Resume a conversation by ID or name' },
  { cmd: '/branch [name]', aliases: '/fork', desc: 'Branch conversation at this point' },
  { cmd: '/rewind', aliases: '/checkpoint', desc: 'Rewind conversation and/or code to a prior point' },
  { cmd: '/rename [name]', aliases: '', desc: 'Rename the current session' },
  { cmd: '/export [filename]', aliases: '', desc: 'Export conversation as plain text' },
  { cmd: '/copy [N]', aliases: '', desc: 'Copy last response (or Nth) to clipboard' },
  { cmd: '/btw <question>', aliases: '', desc: 'Ask a side question without adding to history' },
  { cmd: '/exit', aliases: '/quit', desc: 'Exit the CLI' },
];

/* ── MODEL & DISPLAY ─────────────────────── */
const modelDisplay = [
  { cmd: '/config', aliases: '/settings', desc: 'Open settings (theme, model, output style)' },
  { cmd: '/model [model]', aliases: '', desc: 'Select or change the AI model' },
  { cmd: '/effort [level]', aliases: '', desc: 'Set effort: low, medium, high, max, auto' },
  { cmd: '/fast [on|off]', aliases: '', desc: 'Toggle fast mode' },
  { cmd: '/theme', aliases: '', desc: 'Change color theme (light, dark, daltonized, ANSI)' },
  { cmd: '/color [color]', aliases: '', desc: 'Set prompt bar color for current session' },
  { cmd: '/statusline', aliases: '', desc: 'Configure the status line display' },
  { cmd: '/vim', aliases: '', desc: 'Toggle between Vim and Normal editing modes' },
  { cmd: '/keybindings', aliases: '', desc: 'Open keybindings configuration file' },
  { cmd: '/terminal-setup', aliases: '', desc: 'Configure terminal keybindings (Shift+Enter, etc.)' },
  { cmd: '/voice', aliases: '', desc: 'Toggle push-to-talk voice dictation' },
];

/* ── CODE & PROJECTS ─────────────────────── */
const codeProjects = [
  { cmd: '/init', aliases: '', desc: 'Initialize project with a CLAUDE.md guide' },
  { cmd: '/memory', aliases: '', desc: 'Edit CLAUDE.md memory files and auto-memory' },
  { cmd: '/context', aliases: '', desc: 'Visualize current context usage as a grid' },
  { cmd: '/diff', aliases: '', desc: 'Interactive diff viewer for uncommitted changes' },
  { cmd: '/plan [description]', aliases: '', desc: 'Enter plan mode (optionally with a task)' },
  { cmd: '/tasks', aliases: '', desc: 'List and manage background tasks' },
  { cmd: '/sandbox', aliases: '', desc: 'Toggle sandbox mode' },
  { cmd: '/security-review', aliases: '', desc: 'Analyze branch changes for security vulnerabilities' },
  { cmd: '/pr-comments [PR]', aliases: '', desc: 'Fetch and display GitHub PR comments' },
  { cmd: '/add-dir <path>', aliases: '', desc: 'Add a working directory for the session' },
];

/* ── INTEGRATIONS ────────────────────────── */
const integrations = [
  { cmd: '/agents', aliases: '', desc: 'Manage subagent configurations' },
  { cmd: '/mcp', aliases: '', desc: 'Manage MCP server connections and OAuth' },
  { cmd: '/plugin', aliases: '', desc: 'Manage plugins (install, enable, disable)' },
  { cmd: '/reload-plugins', aliases: '', desc: 'Reload all active plugins without restarting' },
  { cmd: '/skills', aliases: '', desc: 'List all available skills' },
  { cmd: '/hooks', aliases: '', desc: 'View hook configurations for tool events' },
  { cmd: '/permissions', aliases: '/allowed-tools', desc: 'Manage allow, ask, and deny rules' },
  { cmd: '/chrome', aliases: '', desc: 'Configure Claude in Chrome settings' },
  { cmd: '/ide', aliases: '', desc: 'Manage IDE integrations and show status' },
  { cmd: '/desktop', aliases: '/app', desc: 'Continue session in desktop app' },
  { cmd: '/mobile', aliases: '/ios, /android', desc: 'QR code to download mobile app' },
  { cmd: '/remote-control', aliases: '/rc', desc: 'Make session available for remote control' },
  { cmd: '/remote-env', aliases: '', desc: 'Configure default remote environment' },
  { cmd: '/schedule [desc]', aliases: '', desc: 'Create and manage cloud scheduled tasks' },
  { cmd: '/install-github-app', aliases: '', desc: 'Set up Claude GitHub Actions for a repo' },
  { cmd: '/install-slack-app', aliases: '', desc: 'Install the Claude Slack app' },
];

/* ── ACCOUNT & USAGE ─────────────────────── */
const account = [
  { cmd: '/login', aliases: '', desc: 'Sign in to your Anthropic account' },
  { cmd: '/logout', aliases: '', desc: 'Sign out from your account' },
  { cmd: '/cost', aliases: '', desc: 'Show token usage statistics' },
  { cmd: '/usage', aliases: '', desc: 'Show plan usage limits and rate limit status' },
  { cmd: '/extra-usage', aliases: '', desc: 'Configure extra usage when rate-limited' },
  { cmd: '/status', aliases: '', desc: 'Show version, model, account, and connectivity' },
  { cmd: '/stats', aliases: '', desc: 'Visualize daily usage, streaks, and history' },
  { cmd: '/insights', aliases: '', desc: 'Generate a session analysis report' },
  { cmd: '/upgrade', aliases: '', desc: 'Open upgrade page (Pro/Max)' },
  { cmd: '/privacy-settings', aliases: '', desc: 'View and update privacy settings (Pro/Max)' },
  { cmd: '/passes', aliases: '', desc: 'Share a free week of Claude Code' },
  { cmd: '/help', aliases: '', desc: 'Show help and available commands' },
  { cmd: '/feedback', aliases: '/bug', desc: 'Submit feedback about Claude Code' },
  { cmd: '/doctor', aliases: '', desc: 'Diagnose and verify your installation' },
  { cmd: '/release-notes', aliases: '', desc: 'View the full changelog' },
  { cmd: '/stickers', aliases: '', desc: 'Order Claude Code stickers' },
];

/* ── BUNDLED SKILLS ──────────────────────── */
const bundledSkills = [
  { cmd: '/simplify [focus]', aliases: '', desc: 'Review changed files for reuse, quality, and efficiency — then fix' },
  { cmd: '/batch <instruction>', aliases: '', desc: 'Orchestrate large-scale parallel changes across the codebase' },
  { cmd: '/debug [description]', aliases: '', desc: 'Enable debug logging and troubleshoot session issues' },
  { cmd: '/loop [interval] <prompt>', aliases: '', desc: 'Run a prompt repeatedly on an interval (e.g. poll a deploy)' },
  { cmd: '/claude-api', aliases: '', desc: 'Load Claude API and SDK reference for your language' },
];

/* ── KEYBOARD SHORTCUTS ──────────────────── */
const shortcuts = [
  { key: 'Enter / Return', desc: 'Submit message' },
  { key: 'Escape', desc: 'Cancel / exit current action' },
  { key: 'Tab', desc: 'Autocomplete file paths' },
  { key: 'Up / Down', desc: 'Navigate command history' },
  { key: 'Ctrl+R', desc: 'Reverse search through history' },
  { key: 'Ctrl+E', desc: 'Open external editor for input' },
  { key: 'Ctrl+B', desc: 'Background a long-running process' },
  { key: '! <cmd>', desc: 'Execute shell command directly (bash mode)' },
];

/* ── CLI FLAGS ───────────────────────────── */
const cliExecution = [
  { flag: '--model <name>', desc: 'Set AI model (sonnet, opus, haiku)' },
  { flag: '-p, --print', desc: 'Non-interactive print mode for scripting' },
  { flag: '-v, --version', desc: 'Show version number' },
  { flag: '-n, --name <name>', desc: 'Set session display name' },
];

const cliSessions = [
  { flag: '--continue', desc: 'Resume most recent conversation' },
  { flag: '--resume <id>', desc: 'Resume a specific session by ID' },
  { flag: '--from-pr <num>', desc: 'Resume session linked to a GitHub PR' },
  { flag: '--fork-session', desc: 'Fork session with full history retained' },
  { flag: '-w, --worktree', desc: 'Start in an isolated git worktree' },
  { flag: '--no-session-persistence', desc: 'Don\'t save session to disk' },
];

const cliPrompt = [
  { flag: '--system-prompt <text>', desc: 'Replace entire system prompt' },
  { flag: '--system-prompt-file <path>', desc: 'Replace system prompt from file' },
  { flag: '--append-system-prompt <text>', desc: 'Append text to default prompt' },
  { flag: '--append-system-prompt-file <path>', desc: 'Append file contents to prompt' },
];

const cliTools = [
  { flag: '--allowedTools <tools>', desc: 'Restrict which tools are available' },
  { flag: '--disallowedTools <tools>', desc: 'Block specific tools' },
  { flag: '--dangerously-skip-permissions', desc: 'Bypass all permission prompts' },
  { flag: '--disable-slash-commands', desc: 'Disable all slash commands' },
  { flag: '--permission-mode <mode>', desc: 'Set initial permission mode' },
];

const cliConfig = [
  { flag: '--output-format <fmt>', desc: 'Output format: text, json, stream-json' },
  { flag: '--mcp-config <path>', desc: 'Path to MCP server configuration' },
  { flag: '--max-turns <n>', desc: 'Maximum conversation turns' },
  { flag: '--debug <modules>', desc: 'Enable debug output (e.g. api,mcp)' },
  { flag: '--plugin-dir <path>', desc: 'Directory to load plugins from' },
  { flag: '--no-chrome', desc: 'Disable Chrome browser integration' },
  { flag: '--remote <name>', desc: 'Create web session on claude.ai' },
  { flag: '--remote-control <name>', desc: 'Interactive session with remote control' },
  { flag: '--agents <json>', desc: 'Define ephemeral subagents as JSON' },
];

/* ── VIM MODE ────────────────────────────── */
const vimNav = [
  { key: 'h j k l', desc: 'Move left, down, up, right' },
  { key: 'w / e / b', desc: 'Next word / end of word / back word' },
  { key: '0 / $ / ^', desc: 'Line start / end / first non-blank' },
  { key: 'gg / G', desc: 'Go to start / end of document' },
  { key: 'f<c> / F<c>', desc: 'Find char forward / backward' },
  { key: '; / ,', desc: 'Repeat / reverse last find' },
];

const vimEditing = [
  { key: 'i / a / o', desc: 'Insert before / after / new line below' },
  { key: 'I / A / O', desc: 'Insert at start / end / new line above' },
  { key: 'x', desc: 'Delete character under cursor' },
  { key: 'dd / D', desc: 'Delete line / delete to end of line' },
  { key: 'dw / de / db', desc: 'Delete word / to end / to beginning' },
  { key: 'cw / cc / C', desc: 'Change word / line / to end of line' },
  { key: 'yy / yw / p / P', desc: 'Yank line / word / paste after / before' },
  { key: '. (dot)', desc: 'Repeat last editing command' },
  { key: '> / <', desc: 'Indent / dedent' },
  { key: 'J', desc: 'Join current line with next' },
  { key: 'Esc', desc: 'Return to Normal mode' },
];
---

<Layout title="Cheatsheet — ClaudeBook">
  <!-- NAV -->
  <nav class="nav scrolled">
    <div class="nav-inner">
      <a href={base} class="nav-brand">
        <img src={`${base}logo.png`} alt="" width="32" height="32" />
        <span>ClaudeBook</span>
      </a>
      <div class="nav-links">
        <a href={base}>Home</a>
        <a href={`${base}cheatsheet/`} class="nav-active">Cheatsheet</a>
        <a href="https://github.com/utensils/claudebook" class="nav-gh" target="_blank" rel="noopener">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        </a>
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <section class="cheat-hero">
    <div class="cheat-hero-content">
      <h1 class="cheat-hero-title">
        <span class="cheat-hero-accent">Cheatsheet</span>
        <span class="cheat-hero-sub">every command, shortcut &amp; flag</span>
      </h1>
      <p class="cheat-hero-desc">
        A quick-reference for everything built into Claude Code. Print it, bookmark it, keep it handy.
      </p>
    </div>
  </section>

  <!-- CHEATSHEET CONTENT -->
  <main class="cheat-main">
    <div class="cheat-inner">

      <!-- SECTION: SLASH COMMANDS -->
      <h2 class="cheat-section-title reveal">
        <span class="cheat-section-accent">Built-in Commands</span>
        <span class="cheat-section-sub">type <code>/</code> in Claude Code to browse</span>
      </h2>
      <div class="cheat-grid">

        <!-- Session & Navigation -->
        <div class="cheat-card reveal" style="--card-accent: var(--coral);">
          <div class="cheat-card-header">
            <span class="cheat-card-icon">&#x21bb;</span>
            <h3>Session &amp; Navigation</h3>
          </div>
          <div class="cheat-rows">
            {session.map((item) => (
              <div class="cheat-row">
                <div class="cheat-key">
                  <code>{item.cmd}</code>
                  {item.aliases && <span class="cheat-alias">{item.aliases}</span>}
                </div>
                <div class="cheat-desc">{item.desc}</div>
              </div>
            ))}
          </div>
        </div>

        <!-- Model & Display -->
        <div class="cheat-card reveal" style="--card-accent: var(--teal);">
          <div class="cheat-card-header">
            <span class="cheat-card-icon">&#x2699;</span>
            <h3>Model &amp; Display</h3>
          </div>
          <div class="cheat-rows">
            {modelDisplay.map((item) => (
              <div class="cheat-row">
                <div class="cheat-key">
                  <code>{item.cmd}</code>
                  {item.aliases && <span class="cheat-alias">{item.aliases}</span>}
                </div>
                <div class="cheat-desc">{item.desc}</div>
              </div>
            ))}
          </div>
        </div>

        <!-- Code & Projects -->
        <div class="cheat-card reveal" style="--card-accent: var(--coral-light);">
          <div class="cheat-card-header">
            <span class="cheat-card-icon">&#x2215;</span>
            <h3>Code &amp; Projects</h3>
          </div>
          <div class="cheat-rows">
            {codeProjects.map((item) => (
              <div class="cheat-row">
                <div class="cheat-key">
                  <code>{item.cmd}</code>
                  {item.aliases && <span class="cheat-alias">{item.aliases}</span>}
                </div>
                <div class="cheat-desc">{item.desc}</div>
              </div>
            ))}
          </div>
        </div>

        <!-- Integrations -->
        <div class="cheat-card reveal" style="--card-accent: var(--teal-dark);">
          <div class="cheat-card-header">
            <span class="cheat-card-icon">&#x1F517;</span>
            <h3>Integrations</h3>
          </div>
          <div class="cheat-rows">
            {integrations.map((item) => (
              <div class="cheat-row">
                <div class="cheat-key">
                  <code>{item.cmd}</code>
                  {item.aliases && <span class="cheat-alias">{item.aliases}</span>}
                </div>
                <div class="cheat-desc">{item.desc}</div>
              </div>
            ))}
          </div>
        </div>

        <!-- Account & Usage -->
        <div class="cheat-card reveal" style="--card-accent: var(--golden-dark);">
          <div class="cheat-card-header">
            <span class="cheat-card-icon">&#x1F464;</span>
            <h3>Account &amp; Usage</h3>
          </div>
          <div class="cheat-rows">
            {account.map((item) => (
              <div class="cheat-row">
                <div class="cheat-key">
                  <code>{item.cmd}</code>
                  {item.aliases && <span class="cheat-alias">{item.aliases}</span>}
                </div>
                <div class="cheat-desc">{item.desc}</div>
              </div>
            ))}
          </div>
        </div>

        <!-- Bundled Skills -->
        <div class="cheat-card cheat-card-highlight reveal" style="--card-accent: var(--coral);">
          <div class="cheat-card-header">
            <span class="cheat-card-icon">&#x2728;</span>
            <h3>Bundled Skills</h3>
          </div>
          <p class="cheat-card-subtitle">Prompt-based skills that ship with Claude Code. They orchestrate multi-step work using Claude's tools.</p>
          <div class="cheat-rows">
            {bundledSkills.map((item) => (
              <div class="cheat-row">
                <div class="cheat-key">
                  <code>{item.cmd}</code>
                </div>
                <div class="cheat-desc">{item.desc}</div>
              </div>
            ))}
          </div>
        </div>

      </div>

      <!-- SECTION: KEYBOARD SHORTCUTS -->
      <h2 class="cheat-section-title reveal">
        <span class="cheat-section-accent">Keyboard Shortcuts</span>
        <span class="cheat-section-sub">interactive mode essentials</span>
      </h2>
      <div class="cheat-grid">

        <!-- Shortcuts -->
        <div class="cheat-card reveal" style="--card-accent: var(--teal);">
          <div class="cheat-card-header">
            <span class="cheat-card-icon">&#x2318;</span>
            <h3>General</h3>
          </div>
          <div class="cheat-rows">
            {shortcuts.map((item) => (
              <div class="cheat-row">
                <div class="cheat-key"><kbd>{item.key}</kbd></div>
                <div class="cheat-desc">{item.desc}</div>
              </div>
            ))}
          </div>
        </div>

        <!-- Vim: Navigation -->
        <div class="cheat-card reveal" style="--card-accent: var(--teal-dark);">
          <div class="cheat-card-header">
            <span class="cheat-card-icon">&#x25B6;</span>
            <h3>Vim &mdash; Navigation</h3>
          </div>
          <div class="cheat-rows">
            {vimNav.map((item) => (
              <div class="cheat-row">
                <div class="cheat-key"><kbd>{item.key}</kbd></div>
                <div class="cheat-desc">{item.desc}</div>
              </div>
            ))}
          </div>
          <div class="cheat-card-note">
            Enable with <code>/vim</code> or set <code>editorMode: "vim"</code> in config
          </div>
        </div>

        <!-- Vim: Editing -->
        <div class="cheat-card reveal" style="--card-accent: var(--teal-dark);">
          <div class="cheat-card-header">
            <span class="cheat-card-icon">&#x270D;</span>
            <h3>Vim &mdash; Editing</h3>
          </div>
          <div class="cheat-rows">
            {vimEditing.map((item) => (
              <div class="cheat-row">
                <div class="cheat-key"><kbd>{item.key}</kbd></div>
                <div class="cheat-desc">{item.desc}</div>
              </div>
            ))}
          </div>
        </div>

      </div>

      <!-- SECTION: CLI FLAGS -->
      <h2 class="cheat-section-title reveal">
        <span class="cheat-section-accent">CLI Flags</span>
        <span class="cheat-section-sub">launch-time options for <code>claude</code></span>
      </h2>
      <div class="cheat-grid">

        <!-- CLI: Execution -->
        <div class="cheat-card reveal" style="--card-accent: var(--golden-dark);">
          <div class="cheat-card-header">
            <span class="cheat-card-icon">$</span>
            <h3>Execution</h3>
          </div>
          <div class="cheat-rows">
            {cliExecution.map((item) => (
              <div class="cheat-row">
                <div class="cheat-key"><code>{item.flag}</code></div>
                <div class="cheat-desc">{item.desc}</div>
              </div>
            ))}
          </div>
        </div>

        <!-- CLI: Sessions -->
        <div class="cheat-card reveal" style="--card-accent: var(--golden-dark);">
          <div class="cheat-card-header">
            <span class="cheat-card-icon">&#x21bb;</span>
            <h3>Sessions</h3>
          </div>
          <div class="cheat-rows">
            {cliSessions.map((item) => (
              <div class="cheat-row">
                <div class="cheat-key"><code>{item.flag}</code></div>
                <div class="cheat-desc">{item.desc}</div>
              </div>
            ))}
          </div>
        </div>

        <!-- CLI: System Prompt -->
        <div class="cheat-card reveal" style="--card-accent: var(--golden-dark);">
          <div class="cheat-card-header">
            <span class="cheat-card-icon">&#x270E;</span>
            <h3>System Prompt</h3>
          </div>
          <div class="cheat-rows">
            {cliPrompt.map((item) => (
              <div class="cheat-row">
                <div class="cheat-key"><code>{item.flag}</code></div>
                <div class="cheat-desc">{item.desc}</div>
              </div>
            ))}
          </div>
        </div>

        <!-- CLI: Tools & Permissions -->
        <div class="cheat-card reveal" style="--card-accent: var(--golden-dark);">
          <div class="cheat-card-header">
            <span class="cheat-card-icon">&#x1F512;</span>
            <h3>Tools &amp; Permissions</h3>
          </div>
          <div class="cheat-rows">
            {cliTools.map((item) => (
              <div class="cheat-row">
                <div class="cheat-key"><code>{item.flag}</code></div>
                <div class="cheat-desc">{item.desc}</div>
              </div>
            ))}
          </div>
        </div>

        <!-- CLI: Config & Integration -->
        <div class="cheat-card reveal" style="--card-accent: var(--golden-dark);">
          <div class="cheat-card-header">
            <span class="cheat-card-icon">&#x2699;</span>
            <h3>Config &amp; Integration</h3>
          </div>
          <div class="cheat-rows">
            {cliConfig.map((item) => (
              <div class="cheat-row">
                <div class="cheat-key"><code>{item.flag}</code></div>
                <div class="cheat-desc">{item.desc}</div>
              </div>
            ))}
          </div>
        </div>

      </div>

      <!-- SECTION: CUSTOM COMMANDS -->
      <h2 class="cheat-section-title reveal">
        <span class="cheat-section-accent">Custom Skills</span>
        <span class="cheat-section-sub">extend Claude Code with your own commands</span>
      </h2>
      <div class="cheat-grid">

        <div class="cheat-card cheat-card-highlight reveal" style="--card-accent: var(--coral-light);">
          <div class="cheat-card-header">
            <span class="cheat-card-icon">&#x1F4DD;</span>
            <h3>Create Your Own</h3>
          </div>
          <p class="cheat-custom-text">
            Add <code>SKILL.md</code> files to <code>.claude/skills/</code> (or <code>.md</code> files to <code>.claude/commands/</code>) and they become slash commands.
          </p>
          <div class="cheat-custom-tips">
            <div class="cheat-custom-tip">
              <strong>$ARGUMENTS</strong>
              <span>Reference user input for parameterized commands</span>
            </div>
            <div class="cheat-custom-tip">
              <strong>context: fork</strong>
              <span>Run in a subagent for isolated execution</span>
            </div>
            <div class="cheat-custom-tip">
              <strong>allowed-tools</strong>
              <span>Restrict which tools the skill can access</span>
            </div>
            <div class="cheat-custom-tip">
              <strong>!`command`</strong>
              <span>Inject dynamic shell output into skill content</span>
            </div>
          </div>
          <div class="cheat-card-cta">
            <a href={base}>Browse ClaudeBook recipes &rarr;</a>
          </div>
        </div>

        <div class="cheat-card reveal" style="--card-accent: var(--coral-light);">
          <div class="cheat-card-header">
            <span class="cheat-card-icon">&#x1F4C1;</span>
            <h3>Skill Locations</h3>
          </div>
